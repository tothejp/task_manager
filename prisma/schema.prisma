// 임무분담표(TaskShare) Prisma 스키마
// 참고: task_manager_PRD.md 6장 데이터 모델 초안
// - 팀 단위 데이터 격리는 Supabase RLS로 강제한다 (supabase/rls_policies.sql 참고)
// - skill_tags는 팀별 커스텀 태그이므로 배열 컬럼 대신 조인 테이블로 관리한다
//   (관리자만 쓰기 가능해야 하는 RLS 요구사항을 테이블 단위로 분리하기 위함)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum AvailabilityStatus {
  AVAILABLE // 가용
  VACATION // 휴가
  DAY_OFF // 휴무
}

// 과업 반복 주기와 개인 일정(휴무일) 반복 주기에서 공통으로 사용
enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum AssignmentStatus {
  EMPTY // 공백 (휴가 등으로 인해 배정이 비워진 상태)
  ASSIGNED // 배정
  COMPLETED // 완료
}

enum AssignedBy {
  MANUAL
  AUTO
}

model Team {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  inviteCode String   @unique @default(cuid()) @map("invite_code")
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  members   Member[]
  skillTags SkillTag[]
  tasks     Task[]

  @@map("teams")
}

// Supabase auth.users(id)를 참조한다. auth 스키마는 Prisma가 직접 관리하지 않으므로
// 관계(relation)가 아닌 단순 UUID 컬럼으로 저장하고 애플리케이션/RLS 레벨에서 연결한다.
model Member {
  id        String     @id @default(uuid()) @db.Uuid
  teamId    String     @map("team_id") @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  role      MemberRole
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  team           Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  skills         MemberSkill[]
  availabilities Availability[]
  assignments    Assignment[]

  @@index([teamId])
  @@map("members")
}

// 팀별 스킬 태그 카탈로그 (예: "지게차운전"). 관리자만 생성/삭제 가능 (RLS로 강제)
model SkillTag {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  team               Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberSkills       MemberSkill[]
  taskRequiredSkills TaskRequiredSkill[]

  @@unique([teamId, name])
  @@index([teamId])
  @@map("skill_tags")
}

// 구성원-스킬 매핑. 관리자만 쓰기 가능 (RLS로 강제), 팀원은 read-only
model MemberSkill {
  memberId   String   @map("member_id") @db.Uuid
  skillTagId String   @map("skill_tag_id") @db.Uuid
  grantedBy  String   @map("granted_by") @db.Uuid
  grantedAt  DateTime @default(now()) @map("granted_at")

  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  skillTag SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@id([memberId, skillTagId])
  @@index([skillTagId])
  @@map("member_skills")
}

// 팀원 개인 일정 입력 (근무 가능일/휴가/휴무일)
model Availability {
  id         String             @id @default(uuid()) @db.Uuid
  memberId   String             @map("member_id") @db.Uuid
  date       DateTime           @db.Date
  status     AvailabilityStatus
  repeatType RepeatType         @default(NONE) @map("repeat_type")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, date])
  @@index([memberId, date])
  @@map("availabilities")
}

// 과업. 진행 시간(startTime~endTime)과 요구 인원수, 필수 스킬을 가진다
model Task {
  id                String     @id @default(uuid()) @db.Uuid
  teamId            String     @map("team_id") @db.Uuid
  title             String
  description       String?
  date              DateTime   @db.Date
  startTime         DateTime   @map("start_time") @db.Time
  endTime           DateTime   @map("end_time") @db.Time
  requiredHeadcount Int        @map("required_headcount")
  repeatType        RepeatType @default(NONE) @map("repeat_type")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  team           Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requiredSkills TaskRequiredSkill[]
  assignments    Assignment[]

  @@index([teamId, date])
  @@map("tasks")
}

// 과업-필수 스킬 매핑 (1개 이상 지정 가능)
model TaskRequiredSkill {
  taskId     String @map("task_id") @db.Uuid
  skillTagId String @map("skill_tag_id") @db.Uuid

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skillTag SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@id([taskId, skillTagId])
  @@index([skillTagId])
  @@map("task_required_skills")
}

// 과업-인원 배정. skillOverride는 필수 스킬 미보유자를 경고 모달 확인 후 배정했는지 추적한다
model Assignment {
  id            String           @id @default(uuid()) @db.Uuid
  taskId        String           @map("task_id") @db.Uuid
  memberId      String           @map("member_id") @db.Uuid
  date          DateTime         @db.Date
  status        AssignmentStatus @default(ASSIGNED)
  assignedBy    AssignedBy       @map("assigned_by")
  skillOverride Boolean          @default(false) @map("skill_override")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // 같은 과업에 동일 인원이 중복 배정되는 것을 DB 레벨에서도 방지한다.
  // 시간대가 겹치는 "다른" 과업 간의 중복 배정 차단은 애플리케이션 레벨
  // 공통 유틸(isTimeOverlapping)로 판단한다 (DB 제약만으로는 표현 불가).
  @@unique([taskId, memberId])
  @@index([memberId, date])
  @@map("assignments")
}
