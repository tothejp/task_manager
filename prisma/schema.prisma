// 임무분담표(TaskShare) Prisma 스키마
// 참고: task_manager_PRD.md 6장 데이터 모델 초안
// - 팀 단위 데이터 격리는 Supabase RLS로 강제한다 (supabase/rls_policies.sql 참고)
// - 런타임 쿼리는 Supabase 클라이언트로, Prisma는 스키마/마이그레이션 전용

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MemberRole {
  admin
  member
}

// pending: 초대코드로 합류해 관리자 승인 대기 중. 팀 생성자(관리자)는 기본값 active로 즉시 활성화.
enum MemberStatus {
  active
  pending
}

enum AvailabilityStatus {
  available
  vacation
  dayoff
}

// NONE 없음 — 반복 없는 경우는 null로 저장
enum RepeatType {
  daily
  weekly
  monthly
}

// vacant: 휴가 등으로 공백 전환된 상태
enum AssignmentStatus {
  assigned
  vacant
  completed
}

enum AssignedBy {
  manual
  auto
}

model Team {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  inviteCode String   @unique @default(cuid()) @map("invite_code")
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  members   Member[]
  skillTags SkillTag[]
  tasks     Task[]

  @@map("teams")
}

model Member {
  id        String     @id @default(uuid()) @db.Uuid
  teamId    String     @map("team_id") @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  role      MemberRole
  status    MemberStatus @default(active)
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  team           Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  skills         MemberSkill[]
  availabilities Availability[]
  assignments    Assignment[]

  @@index([teamId])
  @@map("members")
}

// 팀별 스킬 태그 카탈로그. 관리자만 생성/삭제 가능 (RLS로 강제)
model SkillTag {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberSkills MemberSkill[]
  taskSkills   TaskSkill[]

  @@unique([teamId, name])
  @@index([teamId])
  @@map("skill_tags")
}

// 구성원-스킬 매핑. 관리자만 쓰기 가능 (RLS로 강제)
model MemberSkill {
  memberId   String @map("member_id") @db.Uuid
  skillTagId String @map("skill_tag_id") @db.Uuid

  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  skillTag SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@id([memberId, skillTagId])
  @@index([skillTagId])
  @@map("member_skills")
}

// 팀원 개인 일정. start_date = end_date = 날짜 (row-per-day), 삭제 후 재삽입으로 갱신
model Availability {
  id          String             @id @default(uuid()) @db.Uuid
  memberId    String             @map("member_id") @db.Uuid
  startDate   DateTime           @map("start_date") @db.Date
  endDate     DateTime           @map("end_date") @db.Date
  status      AvailabilityStatus
  repeatType  RepeatType?        @map("repeat_type")
  repeatUntil DateTime?          @map("repeat_until") @db.Date
  parentId    String?            @map("parent_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, startDate])
  @@map("availabilities")
}

model Task {
  id                String      @id @default(uuid()) @db.Uuid
  teamId            String      @map("team_id") @db.Uuid
  title             String
  description       String?
  date              DateTime    @db.Date
  startTime         DateTime    @map("start_time") @db.Time
  endTime           DateTime    @map("end_time") @db.Time
  requiredHeadcount Int         @map("required_headcount")
  repeatType        RepeatType? @map("repeat_type")
  repeatUntil       DateTime?   @map("repeat_until") @db.Date
  parentId          String?     @map("parent_id") @db.Uuid
  createdAt         DateTime    @default(now()) @map("created_at")

  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  taskSkills  TaskSkill[]
  assignments Assignment[]

  @@index([teamId, date])
  @@map("tasks")
}

// 과업-필수 스킬 매핑
model TaskSkill {
  taskId     String @map("task_id") @db.Uuid
  skillTagId String @map("skill_tag_id") @db.Uuid

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skillTag SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@id([taskId, skillTagId])
  @@index([skillTagId])
  @@map("task_skills")
}

// skillOverride: 필수 스킬 미보유자를 경고 모달 확인 후 배정한 경우 true
model Assignment {
  id            String           @id @default(uuid()) @db.Uuid
  taskId        String           @map("task_id") @db.Uuid
  memberId      String           @map("member_id") @db.Uuid
  status        AssignmentStatus @default(assigned)
  assignedBy    AssignedBy       @map("assigned_by")
  skillOverride Boolean          @default(false) @map("skill_override")
  createdAt     DateTime         @default(now()) @map("created_at")

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([taskId, memberId])
  @@map("assignments")
}
