# 로컬 개발 서버 주소. 이메일 인증 콜백(emailRedirectTo) 등에 사용된다
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase 프로젝트 설정 (Supabase 대시보드 > Project Settings > API / Database에서 확인)

# Prisma가 마이그레이션/쿼리에 사용하는 연결 문자열 (Connection Pooling 사용 시 pgbouncer 포트)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# Prisma 마이그레이션 시 direct connection이 필요한 경우 사용 (pgbouncer 미경유)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# 브라우저(클라이언트)에서 사용하는 공개 값
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"

# 서버 전용 관리자 키. 절대 NEXT_PUBLIC_ 접두사를 붙이지 않고, 브라우저로 노출하지 않는다.
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
